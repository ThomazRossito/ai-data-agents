# =============================================================
# DATA AGENTS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do arquivo .env (já está no .gitignore)
# =============================================================


# =============================================================
# MOONSHOT / KIMI K2 (compat. Anthropic)
# =============================================================
#
# O claude-agent-sdk fala o protocolo da Messages API da Anthropic. A Moonshot
# expõe um endpoint compatível em /anthropic, então reutilizamos as variáveis
# ANTHROPIC_API_KEY e ANTHROPIC_BASE_URL — porém apontando para a Moonshot.
#
# A chave é da Moonshot (NÃO da Anthropic). Obtenha em:
#   https://platform.moonshot.ai/console/api-keys
ANTHROPIC_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Endpoint compatível com Anthropic da Moonshot (obrigatório).
# Padrão: https://api.moonshot.ai/anthropic
# Para voltar à Anthropic original (Claude), comente esta linha.
ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic


# =============================================================
# DATABRICKS
# =============================================================

DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.XX.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_SQL_WAREHOUSE_ID=XXXXXXXXXXXXXXXX

# Catálogo padrão do Databricks Unity Catalog (usado pelo sql-expert e spark-expert).
# Exemplo: poc_mas, hive_metastore
# DATABRICKS_CATALOG=poc_mas

# --- Databricks Genie (MCP customizado — Conversation API + Space Management) ---
# Resolve o gap do databricks-mcp-server oficial que não expõe as tools de Genie.
# Reutiliza DATABRICKS_HOST e DATABRICKS_TOKEN acima — sem credenciais extras.
#
# ── OPÇÃO 1: Registry com nomes amigáveis (RECOMENDADO) ──────────────────────
# Chave = nome amigável usado pelo agente | Valor = space_id (ID da URL do Space)
# Como encontrar o Space ID:
#   Databricks → AI/BI → Genie → abra o Space → copie o ID numérico da URL
#
DATABRICKS_GENIE_SPACES={"space-a": "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX", "space-b": "YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY"}
DATABRICKS_GENIE_DEFAULT_SPACE=space-a
#
# ── OPÇÃO 2: Space ID direto como default (sem registry) ─────────────────────
# Use se tiver apenas um Genie Space e não quiser o registry.
# DATABRICKS_GENIE_DEFAULT_SPACE=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Comando do servidor (instalado via pip install -e .)
# Conda: /opt/anaconda3/envs/multi_agents/bin/databricks-genie-mcp
DATABRICKS_GENIE_COMMAND=databricks-genie-mcp

# --- Databricks App (opcional — publicação de apps no Databricks) ---
# DATABRICKS_APP_NAME=app-gtm-mas-genie
# DATABRICKS_APP_DESCRIPTION=App para o projeto de Data Agents
# DATABRICKS_APP_OWNER=seu-email@empresa.com

# --- Databricks Lakebase / PostgreSQL gerenciado (opcional) ---
# DATABRICKS_LAKEBASE_HOST=ep-XXXXXXXXXX.database.eastus.azuredatabricks.net
# DATABRICKS_LAKEBASE_PORT=5432
# DATABRICKS_LAKEBASE_DATABASE=databricks_postgres
# DATABRICKS_LAKEBASE_PROJECT=lakb-projeto
# DATABRICKS_LAKEBASE_OWNER=seu-email@empresa.com


# =============================================================
# MICROSOFT FABRIC / AZURE
# =============================================================

AZURE_TENANT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
AZURE_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FABRIC_WORKSPACE_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1
# GUID do Lakehouse alvo para operações de ontologia (upload TTL, notebook).
# Obtenha: Fabric REST API GET /v1/workspaces/{id}/items → filtre type=Lakehouse
FABRIC_LAKEHOUSE_ONTOLOGIA_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- Fabric RTI (Eventhouse / Kusto) ---
KUSTO_SERVICE_URI=https://XXXXXXXXXXXXXXXXXXXXXXXX.z1.kusto.fabric.microsoft.com
KUSTO_SERVICE_DEFAULT_DB=my_database

# --- Fabric SQL Analytics Endpoint (MCP customizado — multi-lakehouse) ---
# Conecta ao SQL Analytics Endpoint via TDS (pyodbc + AAD Bearer Token).
# Resolve a limitação da REST API que só enxerga o schema dbo.
#
# ── OPÇÃO 1: Registry multi-lakehouse (RECOMENDADO) ──────────────────────────
# Chave = nome | Valor = SQL endpoint (Portal Fabric → Lakehouse → SQL Analytics Endpoint → "Server")
#
FABRIC_SQL_LAKEHOUSES={"lakehouse-a": "XXXXXXXXXXXXXXXXXXXXXXXX.datawarehouse.fabric.microsoft.com", "lakehouse-b": "YYYYYYYYYYYYYYYYYYYYYYYY.datawarehouse.fabric.microsoft.com"}
FABRIC_SQL_DEFAULT_LAKEHOUSE=lakehouse-a
#
# ── OPÇÃO 2: Variável simples (apenas 1 lakehouse) ───────────────────────────
# FABRIC_SQL_ENDPOINT=XXXXXXXXXXXXXXXXXXXXXXXX.datawarehouse.fabric.microsoft.com
# FABRIC_LAKEHOUSE_NAME=meu-lakehouse

# ── Pré-requisito de sistema (uma vez por máquina) ───────────────────────────
# macOS:
#   brew tap microsoft/mssql-release https://github.com/Microsoft/homebrew-mssql-release
#   HOMEBREW_ACCEPT_EULA=Y brew install msodbcsql18
# Linux:
#   https://learn.microsoft.com/sql/connect/odbc/linux-mac/installing-the-microsoft-odbc-driver-for-sql-server

# Comando do servidor (instalado via pip install -e .)
# Conda: /opt/anaconda3/envs/multi_agents/bin/fabric-sql-mcp
FABRIC_SQL_COMMAND=fabric-sql-mcp

# --- Fabric Community MCP ---
# Conda: /opt/anaconda3/envs/multi_agents/bin/microsoft-fabric-mcp
FABRIC_COMMUNITY_COMMAND=microsoft-fabric-mcp

# --- Fabric Semantic MCP (introspecção de Semantic Models: TMDL, DAX, RLS) ---
# Reutiliza credenciais Azure (AZURE_TENANT_ID + AZURE_CLIENT_ID + AZURE_CLIENT_SECRET).
# Requer: Power BI Admin Portal → Tenant Settings → Developer Settings →
#         "Allow service principals to use Power BI APIs" → habilitado.
# Conda: /opt/anaconda3/envs/multi_agents/bin/fabric-semantic-mcp
FABRIC_SEMANTIC_COMMAND=fabric-semantic-mcp

# --- Fabric Ontology MCP (IQ Ontology — entity types, relationship types, bindings) ---
# Auth via Azure CLI (az login) — sem credenciais extras além das Azure acima.
# Requer: az login no ambiente antes de iniciar o servidor.
# Conda: /opt/anaconda3/envs/multi_agents/bin/fabric-ontology-mcp
FABRIC_ONTOLOGY_COMMAND=fabric-ontology-mcp


# =============================================================
# UI / MONITORING — Portas
# =============================================================
# Portas distintas do projeto original (data-agents = 8503/8501) para permitir
# rodar os dois projetos lado a lado sem conflito.
CHAINLIT_PORT=8513
MONITOR_PORT=8511


# =============================================================
# CONFIGURAÇÕES DO SISTEMA
# =============================================================

# Modelo padrão para o Supervisor e agentes sem TIER_MODEL_MAP configurado.
# Família Kimi K2.6 (Moonshot, abril/2026):
#   kimi-k2.6   — modelo único da API, 1T params MoE, 256k context.
#                 Thinking é controlado via parâmetro (não há modelo separado).
#                 No `/plan` (DOMA Full) o supervisor envia `thinking={"type":"adaptive"}`.
DEFAULT_MODEL=kimi-k2.6

# Budget máximo por sessão em USD. Sessão encerrada automaticamente ao atingir o limite.
MAX_BUDGET_USD=1.0

# Número máximo de tool calls do Supervisor por sessão.
MAX_TURNS=50

# Nível de log para arquivo JSONL de auditoria (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO

# Nível de log para o console (o que o usuário vê no terminal).
# WARNING = esconde logs operacionais — recomendado para uso interativo.
# INFO = exibe todos os logs operacionais (output comprimido, custo, etc.)
CONSOLE_LOG_LEVEL=WARNING

# Caminho do arquivo de log de auditoria (todas as tool calls registradas).
AUDIT_LOG_PATH=./logs/audit.jsonl

# --- Model Routing por Tier ---
# Mapeamento tier -> modelo. Sobrescreve o `model:` do frontmatter de cada agente.
# Como K2.6 é o único modelo na API da Moonshot atualmente, deixar VAZIO faz com
# que todos os agentes usem `kimi-k2.6` (declarado no frontmatter de cada .md).
#
# A diferenciação entre tiers acontece via TIER_TURNS_MAP e TIER_EFFORT_MAP abaixo,
# não mais via modelo. Ative este mapa apenas se quiser direcionar algum tier para
# um modelo lateral (ex: kimi-k2.5 com vision para um agente que processa imagens).
#
# TIER_MODEL_MAP={"T1": "kimi-k2.6", "T2": "kimi-k2.6", "T3": "kimi-k2.6"}

# --- Número máximo de turns por tier ---
# Limita tool calls do sub-agente. T1 (pipelines complexos) precisa de mais turns.
# TIER_TURNS_MAP={"T0": 3, "T1": 20, "T2": 12, "T3": 5}

# --- Effort por tier ---
# "high": raciocínio mais profundo (T1) | "medium": balanceado (T2) | "low": rápido (T0/T3)
# TIER_EFFORT_MAP={"T0": "low", "T1": "high", "T2": "medium", "T3": "low"}

# --- Permissões dos Agentes ---
# "bypassPermissions": execução sem confirmação — necessário para agentes que fazem
#   writes em sistemas externos (OneLake upload, criação de itens Fabric, etc.)
# "acceptEdits": pede confirmação antes de operações write/execute — auditoria manual.
# Sem esta variável: Claude Code prompta o usuário em cada operação write (default interativo).
AGENT_PERMISSION_MODE=bypassPermissions

# --- KB Injection ---
# Se true, injeta os index.md das Knowledge Bases no prompt de cada agente.
# Desabilite para economizar tokens.
# INJECT_KB_INDEX=true

# --- Idle Timeout ---
# Minutos de inatividade antes de oferecer reset automático. 0 = desabilitado.
# IDLE_TIMEOUT_MINUTES=30


# =============================================================
# MEMORY SYSTEM (Memória Persistente)
# =============================================================

# Habilita o sistema de memória persistente (captura + retrieval via Sonnet lateral).
# Custo do retrieval: ~$0.003-0.01 por query. Desabilite para economizar.
MEMORY_ENABLED=true

# Injeta memórias relevantes no system prompt antes de cada query ao Supervisor.
MEMORY_RETRIEVAL_ENABLED=true

# Captura automaticamente contexto da sessão via hook PostToolUse.
MEMORY_CAPTURE_ENABLED=true

# --- Configurações avançadas de memória (opcionais) ---
# Modelo usado para extração e retrieval. K2.6 é o único modelo da API.
# Para reduzir custo/latência, o extractor envia `thinking={"type":"disabled"}`.
# MEMORY_EXTRACTOR_MODEL=kimi-k2.6
# MEMORY_RETRIEVAL_MODEL=kimi-k2.6

# Número máximo de memórias recuperadas por query.
# MEMORY_RETRIEVAL_MAX=10

# Velocidade de obsolescência por tipo de memória (em dias).
# None = nunca decai (USER e ARCHITECTURE por padrão).
# MEMORY_DECAY_PROGRESS_DAYS=7
# MEMORY_DECAY_FEEDBACK_DAYS=90
# MEMORY_DECAY_PIPELINE_STATUS_DAYS=14

# Limpeza automática de daily logs compilados (reduz acúmulo de arquivos).
# MEMORY_AUTO_CLEAN_DAILY_LOGS=true
# MEMORY_KEEP_COMPILED_DAYS=30

# --- LESSON_LEARNED (aprendizado autônomo) ---
# Velocidade de obsolescência de lessons aprendidas (default: 30 dias).
# MEMORY_DECAY_LESSON_LEARNED_DAYS=30
# Máximo de lessons ativas por agente. Excesso é prunado por menor confiança.
# MEMORY_LESSON_MAX_PER_AGENT=50

# =============================================================
# S4 AUTONOMOUS MODE (Selective Relaxation)
# =============================================================

# Por padrão OFF. Quando true, o Supervisor auto-aprova delegações read-only,
# single-agent ou de baixo custo sem aguardar confirmação humana.
# Ative apenas quando os agentes estiverem bem calibrados e você confiar no sistema.
# S4_AUTONOMOUS_MODE=false

# Clarity score mínimo (0-5) para auto-aprovação em modo autônomo.
# Abaixo deste valor, o Supervisor solicita confirmação humana mesmo com S4-AUTO=true.
# S4_AUTO_APPROVAL_MIN_CLARITY_SCORE=4

# Custo máximo estimado (USD) para auto-aprovação. Tarefas acima deste limite
# são sempre enviadas para confirmação humana.
# S4_AUTO_APPROVAL_MAX_COST_USD=0.10


# =============================================================
# SKILL AUTO-REFRESH
# =============================================================

# Se true, habilita atualização automática das Skills via scripts/refresh_skills.py.
# O script chama a Anthropic Messages API direta com o tool nativo web_search
# (sem MCP, sem agente). Execute manualmente: make refresh-skills
# SKILL_REFRESH_ENABLED=true
# SKILL_REFRESH_INTERVAL_DAYS=3
# SKILL_REFRESH_DOMAINS=databricks,fabric
# SKILL_REFRESH_MODEL=kimi-k2.6   # opcional — padrão: memory_extractor_model


# =============================================================
# MCPs EXTERNOS — Pesquisa, Código e Integrações
# =============================================================

# --- Context7 (MCP — Documentação atualizada de bibliotecas) ---
# Sem credenciais obrigatórias no plano gratuito (repos públicos).
# Free: 1.000 requests/mês | Pro: $7/seat/mês (repos privados)
# Obtenha em: https://context7.com/plans
# CONTEXT7_API_KEY=       # opcional — deixe vazio para plano gratuito

# --- Tavily (MCP — Busca web otimizada para LLMs) ---
# Free: 1.000 créditos/mês (sem cartão) | Pago: $0.008/crédito
# Obtenha em: https://app.tavily.com/
TAVILY_API_KEY=tvly-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- GitHub (MCP — Gestão de repositórios, issues e pull requests) ---
# Gratuito via Personal Access Token
# Crie em: GitHub → Settings → Developer Settings → PAT (classic)
# Escopos recomendados: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Firecrawl (MCP — Web scraping e crawling estruturado) ---
# Free: 500 créditos/mês | Pago: a partir de $16/mês (3.000 créditos)
# Obtenha em: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- PostgreSQL (MCP — Queries somente leitura em banco PostgreSQL) ---
# Gratuito (open source oficial da Anthropic)
# Formato: postgresql://usuario:senha@host:5432/banco
# Cloud (ex: Supabase, Neon, RDS): adicione ?sslmode=require ao final
# POSTGRES_URL=postgresql://usuario:senha@localhost:5432/meu_banco

# --- Memory MCP (Knowledge Graph persistente de entidades e relações) ---
# Gratuito, sem credenciais. Ativo automaticamente ao iniciar o sistema.
# Complementa o módulo memory/ (episódico): memory_mcp armazena entidades e relações.
# Persistência: arquivo memory.json no diretório de execução.
# (Nenhuma variável necessária — configurado automaticamente)


# =============================================================
# MIGRATION SOURCE — Bancos de Origem para Migração
# =============================================================

# --- Migration Source (MCP customizado — fontes de migração relacionais) ---
# Conecta a bancos SQL Server e PostgreSQL para extração de DDL, views, procedures,
# functions e stats — usado pelo agente migration-expert nas fases de ASSESS e ANALYZE.
#
# ── Registry de fontes (RECOMENDADO) ─────────────────────────────────────────
# Adicione todas as fontes como JSON. Chave = nome | Valor = configuração da conexão.
# type: "sqlserver" | "postgresql"
#
MIGRATION_SOURCES={"ERP_PROD": {"type": "sqlserver", "host": "10.0.0.1", "port": 1433, "database": "ERP", "user": "readonly_user", "password": "XXXX"}, "ANALYTICS": {"type": "postgresql", "host": "10.0.0.2", "port": 5432, "database": "analytics", "user": "postgres", "password": "XXXX"}}
MIGRATION_DEFAULT_SOURCE=ERP_PROD
#
# Com isso o agente pode usar:
#   migration_source_list_sources()                          → lista todas as fontes
#   migration_source_diagnostics()                           → testa a fonte default
#   migration_source_diagnostics(source="ANALYTICS")        → testa fonte específica
#   migration_source_list_tables()                           → tabelas do default
#   migration_source_list_tables(source="ANALYTICS")        → tabelas do PostgreSQL
#
# ── Pré-requisito de sistema para SQL Server (uma vez por máquina) ───────────
# macOS:
#   brew tap microsoft/mssql-release https://github.com/Microsoft/homebrew-mssql-release
#   HOMEBREW_ACCEPT_EULA=Y brew install msodbcsql18
# Linux:
#   https://learn.microsoft.com/sql/connect/odbc/linux-mac/installing-the-microsoft-odbc-driver-for-sql-server
# PostgreSQL: sem dependência de sistema (psycopg2-binary incluso no pyproject.toml)

# Comando do servidor (instalado via pip install -e .)
# Conda: /opt/anaconda3/envs/multi_agents/bin/migration-source-mcp
MIGRATION_SOURCE_COMMAND=migration-source-mcp
